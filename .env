PORT=8787
NODE_ENV=development
CUSTOM_BACKEND_MODE=memory
SESSION_SECRET=uare-local-dev-secret-change-in-prod
ALLOW_DEV_HEADER_AUTH=true
# ── UARE-LLM dual-mode ────────────────────────────────────────────────────
# OLLAMA_URL points to the standalone inference server (uare-llm/apps/standalone/).
# Start it with: python uare-llm/scripts/run_inference.py
# While the standalone server is down, this backend auto-falls back to
# the built-in rule-based narrative engine (generateEnkiNarrative).
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=uare-llm-3b
ENABLE_REQUEST_LOGS=true
CAD_KERNEL_ENABLED=true
CAD_PYTHON_BIN=C:\Users\quant\AppData\Local\Programs\Python\Python311\python.exe
CAD_PYTHON_CANDIDATES=C:\Users\quant\AppData\Local\Programs\Python\Python311\python.exe,py -3.11
OCC_PYTHON_BIN=C:\Users\quant\AppData\Local\Programs\Python\Python311\python.exe
OCC_PYTHON_CANDIDATES=C:\Users\quant\AppData\Local\Programs\Python\Python311\python.exe,py -3.11
ARTIFACT_BASE_URL=
ARTIFACT_STORAGE_MODE=local
OBJECT_STORAGE_MIRROR_DIR=./object_storage_mirror
ARTIFACT_URL_MODE=public
ARTIFACT_ROOT_DIR=
PATENT_SEARCH_MODE=memory
DATA_ROOT_DIR=./data
PRODUCT_STORE_FILE=./data/product-store.json
PROJECT_STORE_FILE=./data/projects.json
MISSION_STORE_FILE=./data/missions.json
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
BILLING_PROVIDER=mock
APP_BASE_URL=http://localhost:8787
CORS_ALLOWED_ORIGINS=http://localhost:8787,http://localhost:3000,http://localhost:5173,http://localhost:4173
TRUSTED_ORIGINS=http://localhost:8787,http://localhost:3000,http://localhost:5173,http://localhost:4173
TRUST_PROXY=false
CONTENT_SECURITY_POLICY=default-src 'self'; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' https://unpkg.com https://cdn.jsdelivr.net; connect-src 'self' https:; font-src 'self' data:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'
REQUEST_BODY_LIMIT=2mb
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=60
GRACEFUL_SHUTDOWN_TIMEOUT_MS=10000
EXPOSE_ERRORS=true
OPS_METRICS_TOKEN=
SESSION_COOKIE_NAME=uare_session
SESSION_COOKIE_SAMESITE=Lax
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_MAX_AGE_SEC=1209600
PUBLIC_HEALTH_DETAILS=true
