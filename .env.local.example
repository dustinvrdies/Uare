PORT=8787
NODE_ENV=development
CUSTOM_BACKEND_MODE=postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/uare
SESSION_SECRET=change-me
ALLOW_DEV_HEADER_AUTH=true
JWT_ISSUER=https://your-auth.example.com
JWT_AUDIENCE=uare-api
JWT_JWKS_URL=https://your-auth.example.com/.well-known/jwks.json
ENABLE_REQUEST_LOGS=true
CAD_KERNEL_ENABLED=false
CAD_PYTHON_BIN=
ARTIFACT_BASE_URL=
ARTIFACT_STORAGE_MODE=local
OBJECT_STORAGE_MIRROR_DIR=./object_storage_mirror
ARTIFACT_URL_MODE=public

ARTIFACT_ROOT_DIR=
PATENT_SEARCH_MODE=memory
DATA_ROOT_DIR=./data
PRODUCT_STORE_FILE=./data/product-store.json
PROJECT_STORE_FILE=./data/projects.json
MISSION_STORE_FILE=./data/missions.json
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
TEAM_STORE_FILE=.team_store.json
APP_BASE_URL=http://localhost:8787
BILLING_PROVIDER=stripe
STRIPE_PRICE_FREE=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=
TEST_PLAN_ID=pro
TEST_ORG_ID=
CORS_ALLOWED_ORIGINS=http://localhost:8787
TRUST_PROXY=false
CONTENT_SECURITY_POLICY=default-src 'self'; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' https://unpkg.com https://cdn.jsdelivr.net; connect-src 'self' https:; font-src 'self' data:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'
REQUEST_BODY_LIMIT=2mb
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=180
AUTH_RATE_LIMIT_MAX=30
GRACEFUL_SHUTDOWN_TIMEOUT_MS=10000
EXPOSE_ERRORS=false
OPS_METRICS_TOKEN=
OPS_ALERT_WEBHOOK_URL=
REQUIRED_PROD_VARS=SESSION_SECRET,APP_BASE_URL,DATABASE_URL,STRIPE_SECRET_KEY,STRIPE_WEBHOOK_SECRET
SESSION_COOKIE_NAME=uare_session
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_SAMESITE=Lax
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_MAX_AGE_SEC=1209600

# Local launcher-friendly defaults can be added automatically.
