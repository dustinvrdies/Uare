PORT=8787
NODE_ENV=production
CUSTOM_BACKEND_MODE=postgres
DATABASE_URL=postgres://uare:change-me@localhost:5432/uare
REDIS_URL=redis://localhost:6379
RATE_LIMIT_MODE=redis
EVENT_BUS_MODE=redis
EVENT_BUS_REDIS_URL=redis://localhost:6379
EVENT_REPLAY_STORE_MODE=postgres
WORKER_STORE_MODE=postgres
JOB_STORE_MODE=postgres
SESSION_SECRET=replace-with-32+-char-random-secret
ALLOW_DEV_HEADER_AUTH=false
JWT_ISSUER=https://your-auth.example.com
JWT_AUDIENCE=uare-api
JWT_JWKS_URL=https://your-auth.example.com/.well-known/jwks.json
ENABLE_REQUEST_LOGS=true
APP_BASE_URL=https://api.your-domain.com
CORS_ALLOWED_ORIGINS=https://app.your-domain.com
TRUSTED_ORIGINS=https://app.your-domain.com,https://api.your-domain.com
TRUST_PROXY=true
SESSION_COOKIE_NAME=uare_session
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_SAMESITE=Lax
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_MAX_AGE_SEC=1209600
SESSION_ABSOLUTE_LIFETIME_SEC=2592000
SESSION_ROLLING_ENABLED=true
CAD_KERNEL_ENABLED=false
CAD_PYTHON_BIN=
ARTIFACT_BASE_URL=
ARTIFACT_STORAGE_MODE=local
OBJECT_STORAGE_MIRROR_DIR=./object_storage_mirror
ARTIFACT_URL_MODE=public
ARTIFACT_ROOT_DIR=
PATENT_SEARCH_MODE=memory
DATA_ROOT_DIR=./data
PRODUCT_STORE_FILE=./data/product-store.json
PROJECT_STORE_FILE=./data/projects.json
MISSION_STORE_FILE=./data/missions.json
BILLING_PROVIDER=stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_TOLERANCE_SEC=300
STRIPE_PRICE_FREE=
STRIPE_PRICE_PRO=
STRIPE_PRICE_STUDIO=
STRIPE_PRICE_ENTERPRISE=
BILLING_SUCCESS_URL=https://app.your-domain.com/billing/success?session_id={CHECKOUT_SESSION_ID}
BILLING_CANCEL_URL=https://app.your-domain.com/billing/cancel
CONTENT_SECURITY_POLICY=default-src 'self'; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' https://unpkg.com https://cdn.jsdelivr.net; connect-src 'self' https:; font-src 'self' data:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'
REQUEST_BODY_LIMIT=2mb
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=180
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=30
GRACEFUL_SHUTDOWN_TIMEOUT_MS=10000
EXPOSE_ERRORS=false
OPS_METRICS_TOKEN=
OPS_ALERT_WEBHOOK_URL=
REQUIRED_PROD_VARS=SESSION_SECRET,APP_BASE_URL,DATABASE_URL,REDIS_URL,STRIPE_SECRET_KEY,STRIPE_WEBHOOK_SECRET

# Fill all production secrets before deployment.
